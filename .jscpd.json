{
  "absolute": true,
  "gitignore": true,
  "ignore": [
    "**/dist/**",
    "**/docs/**",
    "**/examples/**",
    "**/examples2/**",
    "**/example_dtw/**",
    "**/example_ulli/**",
    "**/node_modules/**",
    "**/*.d.ts"
  ],
  "minLines": 8,
  "minTokens": 70,
  "output": "node_modules/.cache/jscpd",
  "reporters": [
    "console",
    "json"
  ],
  "threshold": 0
}
